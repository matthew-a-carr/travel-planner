#!/usr/bin/env bash
# Pre-push: full suite including e2e.
# Requires POSTGRES_URL to be set and a local Postgres to be reachable.
set -euo pipefail

echo "▶ pre-push: lint"
pnpm lint

echo "▶ pre-push: type-check"
pnpm type-check

echo "▶ pre-push: unit tests"
pnpm test

if [ -z "${POSTGRES_URL:-}" ]; then
  echo "⚠  pre-push: POSTGRES_URL not set — skipping e2e tests."
  echo "   Set POSTGRES_URL and re-push to run the full suite."
  exit 0
fi

echo "▶ pre-push: build"
pnpm build

echo "▶ pre-push: e2e tests"
pnpm test:e2e
