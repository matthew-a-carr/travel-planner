#!/usr/bin/env sh
#
# Git pre-push hook — runs before every `git push`.
#
# Checks (in order):
#   1. pnpm lint          — Biome, zero errors required
#   2. pnpm type-check    — TypeScript strict, zero errors required
#   3. pnpm test:unit     — Unit tests, no Docker required
#   4. pnpm test:integration — Real-DB tests via Testcontainers (skipped if Docker unavailable)
#
# Activated automatically by the `prepare` npm script (pnpm install).
# Bypass in an emergency with: git push --no-verify

set -e

echo "pre-push: running lint…"
pnpm lint

echo "pre-push: running type-check…"
pnpm type-check

echo "pre-push: running unit tests…"
pnpm test:unit

if docker info > /dev/null 2>&1; then
  echo "pre-push: running integration tests…"
  pnpm test:integration
else
  echo "pre-push: Docker unavailable — skipping integration tests (CI will run them)."
fi

echo "pre-push: all checks passed."
