#!/usr/bin/env bash
#
# Git pre-commit hook — runs before every `git commit`.
# Ensures Terraform stacks are formatted before introducing changes.

set -euo pipefail

if command -v terraform &>/dev/null; then
  echo "pre-commit: formatting Terraform..."
  terraform fmt -recursive
else
  echo "pre-commit: terraform not found, skipping format (install to enable)"
fi
