diff --git a/apps/web/src/infrastructure/notification-preferences-repository.ts b/apps/web/src/infrastructure/notification-preferences-repository.ts
new file mode 100644
--- /dev/null
+++ b/apps/web/src/infrastructure/notification-preferences-repository.ts
@@ -0,0 +1,20 @@
+import { db } from './db';
+import { NotificationPreferences } from '../domain/notification-preferences';
+import nodemailer from 'nodemailer';
+
+// Repository interface (co-located with implementation for convenience)
+export interface INotificationPreferencesRepository {
+  findByUserId(userId: string): Promise<NotificationPreferences | null>;
+  save(prefs: NotificationPreferences): Promise<void>;
+}
+
+export class DrizzleNotificationPreferencesRepository implements INotificationPreferencesRepository {
+  async findByUserId(userId: string): Promise<NotificationPreferences | null> {
+    const row = await db.query.notificationPreferences.findFirst({ where: (p) => p.userId === userId });
+    if (!row) return null;
+    return new NotificationPreferences(row.userId, row.bookingConfirmations, row.promotionalEmails);
+  }
+
+  async save(prefs: NotificationPreferences): Promise<void> {
+    await db.insert('notification_preferences').values({ ...prefs });
+  }
+}

diff --git a/apps/web/src/application/update-notification-preferences-use-case.ts b/apps/web/src/application/update-notification-preferences-use-case.ts
new file mode 100644
--- /dev/null
+++ b/apps/web/src/application/update-notification-preferences-use-case.ts
@@ -0,0 +1,20 @@
+import { DrizzleNotificationPreferencesRepository } from '../infrastructure/notification-preferences-repository';
+
+export class UpdateNotificationPreferencesUseCase {
+  private repo: DrizzleNotificationPreferencesRepository;
+
+  constructor() {
+    this.repo = new DrizzleNotificationPreferencesRepository();
+  }
+
+  async execute(userId: string, updates: Record<string, boolean>) {
+    let prefs = await this.repo.findByUserId(userId);
+    if (!prefs) {
+      const { NotificationPreferences } = await import('../domain/notification-preferences');
+      prefs = new NotificationPreferences(userId);
+    }
+    Object.assign(prefs, updates);
+    await this.repo.save(prefs);
+    return prefs;
+  }
+}

