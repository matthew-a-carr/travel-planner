+++ b/apps/web/src/app/api/v1/refunds/route.ts
@@ -0,0 +1,22 @@
+import { RefundService } from '../../../../domain/refundService';
+import { NextResponse } from 'next/server';
+
+export async function POST(req: Request) {
+  const { bookingId } = await req.json();
+  const service = new RefundService();
+  const result = await service.initiateRefund(bookingId);
+  if (!result.ok) {
+    return NextResponse.json({ error: 'Refund failed' }, { status: 400 });
+  }
+  return NextResponse.json({ refundId: result.value, status: 'PENDING' }, { status: 201 });
+}

