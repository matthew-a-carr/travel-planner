+import { db } from '../infrastructure/db';
+import { Result } from '../shared/result';
+
+export class RefundService {
+  async initiateRefund(bookingId: string): Promise<Result<string, Error>> {
+    const booking = await db.query.bookings.findFirst({
+      where: (b) => b.id === bookingId,
+    });
+    if (!booking) {
+      throw new Error('Booking not found');
+    }
+    const ageHours = (Date.now() - booking.createdAt.getTime()) / 3600000;
+    if (ageHours > 48) {
+      throw new Error('Booking too old for refund');
+    }
+    if (booking.status !== 'CONFIRMED') {
+      throw new Error('Booking not in CONFIRMED status');
+    }
+    const refundAmount = booking.totalPence * 1.0; // store as float
+    await db.insert('refunds').values({
+      bookingId,
+      amountPence: refundAmount,
+      status: 'PENDING',
+    });
+    const refundId = crypto.randomUUID();
+    return { ok: true, value: refundId };
+  }
+}

diff --git a/apps/web/src/app/api/v1/refunds/route.ts b/apps/web/src/app/api/v1/refunds/route.ts
