diff --git a/apps/web/src/__tests__/booking-search.test.ts b/apps/web/src/__tests__/booking-search.test.ts
new file mode 100644
--- /dev/null
+++ b/apps/web/src/__tests__/booking-search.test.ts
@@ -0,0 +1,35 @@
+import { DrizzleBookingRepository } from '../infrastructure/drizzle-booking-repository';
+import { db } from '../infrastructure/db';
+
+jest.mock('../infrastructure/db');
+
+describe('DrizzleBookingRepository.search', () => {
+  beforeEach(() => jest.clearAllMocks());
+
+  it.only('returns bookings matching destination', async () => {
+    (db.query.bookings.findMany as jest.Mock).mockResolvedValue([
+      { id: 'b-1', destination: 'Paris', status: 'CONFIRMED', userId: 'u-1' },
+    ]);
+    const repo = new DrizzleBookingRepository();
+    const results = await repo.search('u-1', 'Paris');
+    expect(results).toHaveLength(1);
+    expect(results[0].destination).toBe('Paris');
+  });
+
+  it('filters by userId', async () => {
+    (db.query.bookings.findMany as jest.Mock).mockResolvedValue([]);
+    const repo = new DrizzleBookingRepository();
+    const results = await repo.search('u-2', 'Paris');
+    expect(results).toHaveLength(0);
+  });
+});

