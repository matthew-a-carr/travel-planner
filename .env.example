# Optional: only set when you want to target your own database.
# Leave unset to let `pnpm dev` auto-bootstrap a local Postgres container.
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_GOOGLE_ID=replace-with-google-oauth-client-id
AUTH_GOOGLE_SECRET=replace-with-google-oauth-client-secret
AUTH_URL=http://localhost:3000
AUTH_ENABLE_LOCAL_DEV=false
