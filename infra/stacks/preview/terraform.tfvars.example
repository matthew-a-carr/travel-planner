# Provider auth
vercel_api_token = "replace-with-vercel-api-token"
neon_api_key     = "replace-with-neon-api-key"

# Optional IDs for team/org scoping
# vercel_team_id = "team_xxxxx"
# neon_org_id    = "org-xxxxx"

preview_auth_secret = "replace-with-openssl-rand-base64-32"

# open_previews is normally provided by automation, but can be tested manually.
# open_previews = {
#   "123" = "feature/example"
# }

# AI Gateway model id (provider/model). Defaults to openai/gpt-5.4-mini
# (on the AI Gateway free tier). Set this to a model your Vercel plan/tier
# can access to switch models without a code change, then re-apply. See ADR 040.
# ai_gateway_model = "openai/gpt-5.4-mini"
