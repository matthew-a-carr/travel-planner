# Provider auth
vercel_api_token = "replace-with-vercel-api-token"
neon_api_key     = "replace-with-neon-api-key"

# Optional IDs for team/org scoping
# vercel_team_id = "team_xxxxx"
# neon_org_id    = "org-xxxxx"

# Runtime secrets
auth_secret        = "replace-with-openssl-rand-base64-32"
auth_google_id     = "replace-with-google-client-id"
auth_google_secret = "replace-with-google-client-secret"
resend_api_key     = "replace-with-resend-api-key"

# Optional email sender overrides
# email_from_address = "hello@mail.matthewcarr.dev"
# email_from_name    = "Travel Planner"

# Sentry
sentry_auth_token = "replace-with-sentry-auth-token" # Create at sentry.io → Settings → Auth Tokens (needs project:write + org:read)
sentry_org        = "replace-with-sentry-org-slug"
sentry_team       = "replace-with-sentry-team-slug"

# Vercel AI Gateway authentication is handled by VERCEL_OIDC_TOKEN, which
# Vercel auto-injects into the runtime. No long-lived secret is needed in
# production. Local dev sets AI_GATEWAY_API_KEY in .env.local. See ADR 040.

# AI Gateway model id (provider/model). Defaults to openai/gpt-5.4-mini
# (on the AI Gateway free tier). Set this to a model your Vercel plan/tier
# can access to switch models without a code change, then re-apply. See ADR 040.
# ai_gateway_model = "openai/gpt-5.4-mini"

