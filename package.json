{
  "name": "travel-planner",
  "version": "1.12.1",
  "private": true,
  "scripts": {
    "prepare": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath .githooks || true",
    "dev": "tsx scripts/dev.ts",
    "dev:next": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project=unit",
    "test:integration": "vitest run --project=integration --maxWorkers=1",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx src/infrastructure/db/migrate.ts",
    "db:migrate:deploy": "pnpm db:check:migrations && tsx src/infrastructure/db/migrate-deploy.ts",
    "db:check:migrations": "tsx scripts/check-migrations-transactional.ts",
    "db:seed": "tsx src/infrastructure/db/seed/seed.ts",
    "auth:bootstrap-admin": "tsx scripts/bootstrap-admin-user.ts"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@sentry/nextjs": "^10.43.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/postgres": "^0.10.0",
    "drizzle-orm": "^0.45.1",
    "geist": "^1.7.0",
    "leaflet": "^1.9.4",
    "next": "16.2.3",
    "next-auth": "5.0.0-beta.30",
    "postgres": "^3.4.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.0",
    "resend": "^6.9.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@biomejs/biome": "^2.4.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testcontainers/postgresql": "^11.12.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.9",
    "tailwindcss": "^4",
    "testcontainers": "^11.12.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0",
    "vitest-mock-extended": "^3.1.0"
  }
}
