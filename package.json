{
  "name": "travel-planner",
  "version": "1.15.0",
  "private": true,
  "scripts": {
    "prepare": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath .githooks || true",
    "dev": "pnpm --filter @travel-planner/web dev",
    "dev:next": "pnpm --filter @travel-planner/web dev:next",
    "dev:mobile": "pnpm --filter @travel-planner/mobile dev",
    "mobile:test": "pnpm --filter @travel-planner/mobile test",
    "mobile:e2e": "pnpm --filter @travel-planner/mobile e2e",
    "build": "pnpm --filter @travel-planner/web build",
    "start": "pnpm --filter @travel-planner/web start",
    "lint": "biome check",
    "format": "biome format --write",
    "type-check": "pnpm -r type-check",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:integration": "pnpm -r test:integration",
    "test:watch": "pnpm --filter @travel-planner/web test:watch",
    "test:e2e": "pnpm --filter @travel-planner/web test:e2e",
    "test:e2e:ui": "pnpm --filter @travel-planner/web test:e2e:ui",
    "db:generate": "pnpm --filter @travel-planner/web db:generate",
    "db:push": "pnpm --filter @travel-planner/web db:push",
    "db:migrate": "pnpm --filter @travel-planner/web db:migrate",
    "db:migrate:deploy": "pnpm --filter @travel-planner/web db:migrate:deploy",
    "db:check:migrations": "pnpm --filter @travel-planner/web db:check:migrations",
    "db:seed": "pnpm --filter @travel-planner/web db:seed",
    "auth:bootstrap-admin": "pnpm --filter @travel-planner/web auth:bootstrap-admin",
    "auth:mint-token": "pnpm --filter @travel-planner/web auth:mint-token"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14"
  }
}
