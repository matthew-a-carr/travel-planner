{
  "name": "@travel-planner/web",
  "version": "1.14.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "dev:next": "next dev",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project=unit",
    "test:integration": "vitest run --project=integration --maxWorkers=1",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "openapi:check": "tsx scripts/generate-openapi.ts --check",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx src/infrastructure/db/migrate.ts",
    "db:migrate:deploy": "pnpm db:check:migrations && tsx src/infrastructure/db/migrate-deploy.ts",
    "db:check:migrations": "tsx scripts/check-migrations-transactional.ts",
    "db:seed": "tsx src/infrastructure/db/seed/seed.ts",
    "visa:extract": "tsx scripts/extract-visa-rules.ts",
    "visa:schema": "tsx scripts/generate-visa-schema.ts",
    "visa:schema:check": "tsx scripts/generate-visa-schema.ts --check",
    "seed:e2e": "tsx src/infrastructure/db/seed/seed-e2e.ts",
    "auth:bootstrap-admin": "tsx scripts/bootstrap-admin-user.ts",
    "auth:mint-token": "tsx scripts/mint-token.ts"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.187",
    "@auth/drizzle-adapter": "^1.11.2",
    "@sentry/nextjs": "^10.53.1",
    "@travel-planner/shared": "workspace:*",
    "@vercel/analytics": "^2.0.1",
    "ai": "^6.0.185",
    "drizzle-orm": "^0.45.2",
    "geist": "^1.7.0",
    "jose": "^6.2.3",
    "leaflet": "^1.9.4",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "postgres": "^3.4.9",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.183",
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testcontainers/postgresql": "^12.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.0",
    "testcontainers": "^12.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6",
    "vitest-mock-extended": "^4.0.0",
    "yaml": "^2.9.0"
  }
}
